{
  "data": {
    "input_path": "src/data/Assassin_preprocessed.csv",
    "text_column": "text",
    "label_column": "label",
    "positive_label": 1.0
  },
  "split": {
    "indices_path": "experiments/splits/split_indices.json",
    "random_seed": 42,
    "train_size": 0.7,
    "dev_size": 0.15,
    "test_size": 0.15,
    "stratify": true,
    "shuffle": true
  },
  "preprocess": {
    "enabled": true,
    "lower": true,
    "remove_punct": true,
    "remove_numbers": false,
    "normalize_entities_flag": true,
    "remove_noise_flag": true,
    "remove_boilerplate_flag": true,
    "max_words": 1024
  },
  "vectorizer": {
    "type": "tfidf",
    "max_features": 50000,
    "ngram_range": [
      1,
      2
    ],
    "min_df": 2,
    "max_df": 0.95,
    "lowercase": true,
    "strip_accents": "unicode"
  },
  "model": {
    "type": "linear_svc",
    "C": 0.5,
    "class_weight": "balanced",
    "max_iter": 5000
  },
  "output": {
    "experiment_dir": "experiments/linear_svc",
    "model_path": "experiments/linear_svc/model.joblib",
    "vectorizer_path": "experiments/linear_svc/vectorizer.joblib",
    "metrics_path": "experiments/linear_svc/metrics.json"
  }
}